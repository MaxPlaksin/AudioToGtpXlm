{
  "name": "audio-to-gtp-converter",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "postinstall": "mkdir -p public/models/basic-pitch && cp -r node_modules/@spotify/basic-pitch/model/* public/models/basic-pitch/ 2>/dev/null || true && node scripts/copy-alphatab.js",
    "download-model": "bash scripts/download-demucs-model.sh",
    "setup": "bash scripts/setup-separation.sh",
    "install-all": "npm install && npm run setup && npm run download-model",
    "separate": "python scripts/separate_audio.py",
    "server": "cd server && (../.venv/bin/uvicorn main:app --reload --host 0.0.0.0 --port 8000 || uvicorn main:app --reload --host 0.0.0.0 --port 8000)",
    "dev": "concurrently -n vite,server -c blue,magenta \"vite\" \"npm run server\"",
    "build": "node scripts/copy-alphatab.js && tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "deploy": "npm run build && npx vercel --prod",
    "deploy:preview": "npm run build && npx vercel"
  },
  "dependencies": {
    "@coderline/alphatab": "^1.8.1",
    "@coderline/alphatab-vite": "^1.8.1",
    "@spotify/basic-pitch": "^1.0.1",
    "@tonejs/midi": "^2.0.28",
    "demucs-web": "^1.0.2",
    "framer-motion": "^11.11.0",
    "howler": "^2.2.4",
    "midi-writer-js": "^1.7.5",
    "onnxruntime-web": "^1.21.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "vexflow": "^5.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@tailwindcss/postcss": "^4.2.1",
    "@types/howler": "^2.2.11",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1"
  }
}
